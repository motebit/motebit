{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Motebit",
  "version": "0.1.0",
  "identifier": "com.motebit.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm vite build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/128x128.png", "icons/256x256.png", "icons/icon.png"]
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Motebit",
        "width": 400,
        "height": 600,
        "resizable": true,
        "transparent": true,
        "decorations": true
      }
    ]
  }
}

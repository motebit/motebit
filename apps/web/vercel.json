{
  "framework": "vite",
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "ignoreCommand": "git diff --quiet ${VERCEL_GIT_PREVIOUS_SHA:-HEAD^} $VERCEL_GIT_COMMIT_SHA -- apps/web/ packages/ 2>/dev/null || exit 1"
}

{
  "name": "@motebit/web",
  "version": "0.0.0-private",
  "license": "BUSL-1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "golden:update": "docker run --rm -v \"$PWD/../..\":/work -w /work mcr.microsoft.com/playwright:v1.60.0-noble bash -c 'corepack enable && pnpm install --frozen-lockfile && pnpm --filter @motebit/web build && pnpm --filter @motebit/web exec playwright test --project=golden --update-snapshots'"
  },
  "dependencies": {
    "@motebit/ai-core": "workspace:*",
    "@motebit/behavior-engine": "workspace:*",
    "@motebit/browser-persistence": "workspace:*",
    "@motebit/core-identity": "workspace:*",
    "@motebit/crypto": "workspace:*",
    "@motebit/encryption": "workspace:*",
    "@motebit/event-log": "workspace:*",
    "@motebit/gradient": "workspace:*",
    "@motebit/identity-file": "workspace:*",
    "@motebit/mcp-client": "workspace:*",
    "@motebit/memory-graph": "workspace:*",
    "@motebit/panels": "workspace:*",
    "@motebit/planner": "workspace:*",
    "@motebit/policy": "workspace:*",
    "@motebit/policy-invariants": "workspace:*",
    "@motebit/privacy-layer": "workspace:*",
    "@motebit/protocol": "workspace:*",
    "@motebit/render-engine": "workspace:*",
    "@motebit/runtime": "workspace:*",
    "@motebit/sdk": "workspace:*",
    "@motebit/self-knowledge": "workspace:*",
    "@motebit/skills": "workspace:*",
    "@motebit/state-export-client": "workspace:*",
    "@motebit/state-vector": "workspace:*",
    "@motebit/sync-engine": "workspace:*",
    "@motebit/tools": "workspace:*",
    "@motebit/voice": "workspace:*",
    "@motebit/wallet-solana": "workspace:*",
    "buffer": "^6.0.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@noble/ed25519": "~3.1.0",
    "@noble/hashes": "^2.2.0",
    "@playwright/test": "^1.61.1",
    "@types/three": "^0.185.1",
    "@vitest/coverage-v8": "^4.1.10",
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }

{
  "name": "@mote/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@mote/ai-core": "workspace:*",
    "@mote/event-log": "workspace:*",
    "@mote/memory-graph": "workspace:*",
    "@mote/state-vector": "workspace:*",
    "@mote/behavior-engine": "workspace:*",
    "@mote/persistence": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

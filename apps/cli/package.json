{
  "name": "motebit",
  "version": "1.0.0",
  "type": "module",
  "description": "Reference runtime and operator console for sovereign AI agents — REPL, daemon, delegation, MCP server. Persistent Ed25519 identity, signed execution receipts, governance at the boundary.",
  "main": "./dist/index.js",
  "bin": {
    "motebit": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "schema/motebit-yaml-v1.json",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "license": "BSL-1.1",
  "keywords": [
    "motebit",
    "agent",
    "ai",
    "identity",
    "ed25519",
    "cli",
    "repl",
    "daemon",
    "mcp",
    "sovereign"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/apps/cli#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup",
    "build-schema": "tsx scripts/build-schema.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:dogfood": "scripts/federation-dogfood.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:pack": "publint --strict",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/curves": "^1.9.0",
    "@noble/ed25519": "~3.0.1",
    "@noble/hashes": "~1.8.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.0",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/hono": "^2.6.0",
    "better-sqlite3": "^12.0.0",
    "hono": "^4.12.9",
    "sql.js": "^1.14.1",
    "stripe": "^17.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "ws": "^8.20.0",
    "yaml": "^2.6.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@motebit/ai-core": "workspace:*",
    "@motebit/api": "workspace:*",
    "@motebit/behavior-engine": "workspace:*",
    "@motebit/core-identity": "workspace:*",
    "@motebit/crypto": "workspace:*",
    "@motebit/encryption": "workspace:*",
    "@motebit/event-log": "workspace:*",
    "@motebit/gradient": "workspace:*",
    "@motebit/identity-file": "workspace:*",
    "@motebit/mcp-client": "workspace:*",
    "@motebit/mcp-server": "workspace:*",
    "@motebit/memory-graph": "workspace:*",
    "@motebit/persistence": "workspace:*",
    "@motebit/planner": "workspace:*",
    "@motebit/policy": "workspace:*",
    "@motebit/privacy-layer": "workspace:*",
    "@motebit/runtime": "workspace:*",
    "@motebit/sdk": "workspace:*",
    "@motebit/self-knowledge": "workspace:*",
    "@motebit/state-vector": "workspace:*",
    "@motebit/sync-engine": "workspace:*",
    "@motebit/tools": "workspace:*",
    "@motebit/voice": "workspace:*",
    "@motebit/wallet-solana": "workspace:*",
    "@motebit/wire-schemas": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

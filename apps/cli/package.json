{
  "name": "motebit",
  "version": "0.7.0",
  "type": "module",
  "description": "Sovereign AI agent — persistent identity, accumulated trust, governance at the boundary",
  "main": "./dist/index.js",
  "bin": {
    "motebit": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "LICENSE",
    "README.md"
  ],
  "license": "BSL-1.1",
  "keywords": [
    "motebit",
    "agent",
    "ai",
    "identity",
    "ed25519",
    "cli",
    "repl",
    "daemon",
    "mcp",
    "sovereign"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/apps/cli#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ed25519": "~3.0.1",
    "@noble/hashes": "~1.6.0",

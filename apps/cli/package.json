{
  "name": "@motebit/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI for Motebit — a sentient digital companion",
  "main": "./dist/index.js",
  "bin": {
    "motebit": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@motebit/ai-core": "workspace:*",
    "@motebit/event-log": "workspace:*",
    "@motebit/memory-graph": "workspace:*",
    "@motebit/sdk": "workspace:*",
    "@motebit/state-vector": "workspace:*",
    "@motebit/behavior-engine": "workspace:*",
    "@motebit/persistence": "workspace:*",
    "@motebit/sync-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

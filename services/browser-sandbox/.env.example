# Browser-sandbox — Environment Variables
#
# Cloud-hosted Chromium driving the virtual_browser embodiment via the
# computer-use-v1 wire format. Per docs/doctrine/motebit-computer.md
# and spec/computer-use-v1.md §8.1.
#
# Quick start (local dev):
#   cd services/browser-sandbox
#   cp .env.example .env             # fill in MOTEBIT_API_TOKEN
#   pnpm browser:install             # one-time Chromium download (~150 MB)
#   pnpm dev                         # starts on :3500
#
# The runtime's CloudBrowserDispatcher (in @motebit/runtime) connects
# here over HTTP. See packages/runtime/src/cloud-browser-dispatcher.ts.

# ─── Auth (at least one path required) ─────────────────────────────────
#
# v1.5+ supports two auth paths, either-or-both. At least one MUST be
# set or `loadConfig()` throws at boot. `dualAuth` shape: a request is
# accepted if it satisfies EITHER path.
#
#   1. MOTEBIT_TRUSTED_RELAY_PUBKEY (preferred, federation-grade)
#      Pinned hex-encoded Ed25519 public key of the trusted relay.
#      Browser-sandbox accepts relay-signed audience-bound tokens
#      (`aud: "browser-sandbox"`) and verifies the signature against
#      this key. Single trust anchor; the `mid` claim provides per-
#      motebit audit attribution. Set this on motebit.com's deployment.
#      Get the relay's pubkey from `relayIdentity.publicKeyHex` after
#      relay bootstrap (services/relay/src/federation.ts:initRelayIdentity).
#      Rotation: when the relay rotates its identity key, browser-sandbox
#      must be redeployed with the new pubkey to keep verifying.
#
#   2. MOTEBIT_API_TOKEN (legacy, single-tenant local-dev)
#      Bearer token gating every authed endpoint. Must be >= 16 chars.
#      Acceptable for single-tenant deployments where the operator
#      controls bundle distribution (local-dev). NEVER set on a public
#      multi-tenant deployment — the token leaks to every visitor.
#      Marked `@deprecated`; removed once `MOTEBIT_TRUSTED_RELAY_PUBKEY`
#      is the sole production auth path.

# Pinned Ed25519 public key of the trusted relay (64 hex chars).
MOTEBIT_TRUSTED_RELAY_PUBKEY=

# Legacy shared bearer (>= 16 chars). Local-dev only.
MOTEBIT_API_TOKEN=

# ─── Networking ─────────────────────────────────────────────────────────

# Server port (default: 3500)
MOTEBIT_PORT=3500

# ─── Pool sizing ───────────────────────────────────────────────────────

# Hard cap on concurrent Chromium sessions across all callers.
# A context is ~150-200 MB; cap prevents a single misuse from OOMing
# the box. Default: 4.
BROWSER_SANDBOX_MAX_SESSIONS=4

# Idle timeout (ms) before a session is auto-disposed by the reaper.
# Frees Chromium contexts whose motebit forgot to dispose. Default: 600000 (10m).
BROWSER_SANDBOX_IDLE_MS=600000

# ─── Viewport ──────────────────────────────────────────────────────────

# Logical viewport width × height that the service advertises to every
# session on POST /sessions/ensure. Action coordinates live in this
# space; screenshot dimensions match these values.
BROWSER_SANDBOX_VIEWPORT_WIDTH=1280
BROWSER_SANDBOX_VIEWPORT_HEIGHT=800

# Embed Service — Environment Variables
#
# Minimal stateless embedding service (ONNX). Not a motebit-shaped
# participant — no identity, no signed receipts, no relay. Exists as
# glucose for other services that need embeddings.
#
# Quick start:
#   cd services/embed
#   cp .env.example .env
#   pnpm dev                          # starts on :3200

# Server port (default: 3200)
MOTEBIT_PORT=3200

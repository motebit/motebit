# Summarize Service — Environment Variables
#
# Quick start:
#   cd services/summarize
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3201
#
# This is a multi-hop delegating service: summarize_search delegates
# to web-search. The service self-bootstraps its motebit identity on
# first boot into ./data.

# ─── Networking / storage ───────────────────────────────────────────────

# Server port (default: 3201)
MOTEBIT_PORT=3201

# Database path (default: ./data/summarize.db)
MOTEBIT_DB_PATH=./data/summarize.db

# Persistent volume root — identity files live here, survives deploys
MOTEBIT_DATA_DIR=./data

# Bearer token for inbound MCP connections (optional — motebit signed
# tokens are always accepted regardless)
MOTEBIT_AUTH_TOKEN=

# ─── Relay integration (optional) ───────────────────────────────────────

# Sync URL for discovery/registration with the canonical relay
MOTEBIT_SYNC_URL=

# API token for authenticating to the relay
MOTEBIT_API_TOKEN=

# ─── Downstream delegation (web-search) ─────────────────────────────────

# URL of the motebit web-search MCP endpoint the summarize agent delegates
# to for each search hop (default: http://localhost:3200)
WEB_SEARCH_URL=http://localhost:3200

# Auth token for the downstream web-search endpoint (optional)
WEB_SEARCH_AUTH_TOKEN=

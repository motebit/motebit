# Code Review Service — Environment Variables
#
# Quick start:
#   cd services/code-review
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3300
#
# Then from another terminal:
#   motebit
#   > /mcp add code-review http://localhost:3300 --motebit
#   > Review motebit/motebit#42

# ─── Required ───────────────────────────────────────────────────────────

# Claude API key — drives the actual review
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── GitHub auth (pick ONE path, or leave blank for public rate limit) ──

# Path A — static token (simple, doesn't rotate)
# Needs `public_repo` scope for public PRs, `repo` for private
GITHUB_TOKEN=

# Path B — OAuth (auto-refresh, preferred for long-running services)
# All three must be set; takes precedence over GITHUB_TOKEN above
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REFRESH_TOKEN=

# ─── Pricing ────────────────────────────────────────────────────────────

# Price per review in USD (default: 0.50)
MOTEBIT_UNIT_COST=0.50

# ─── Networking / storage ───────────────────────────────────────────────

# Server port (default: 3300)
MOTEBIT_PORT=3300

# Database path (default: ./data/code-review.db)
MOTEBIT_DB_PATH=./data/code-review.db

# Persistent volume root — identity files live here, survives deploys
# On Fly.io: /data. Locally: ./data
MOTEBIT_DATA_DIR=./data

# Public URL advertised to the relay (e.g. https://code-review.fly.dev)
MOTEBIT_PUBLIC_URL=

# ─── Relay integration (optional) ───────────────────────────────────────

# Sync URL for discovery/registration with the canonical relay
MOTEBIT_SYNC_URL=

# Bearer token for inbound MCP connections (optional — motebit signed
# tokens are always accepted regardless)
MOTEBIT_AUTH_TOKEN=

# API token for authenticating to the relay
MOTEBIT_API_TOKEN=

# Auditor Service — Environment Variables ("The Auditor" archetype)
#
# Quick start (requires a relay to audit against):
#   cd services/auditor
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3600
#
# Delegate an audit:
#   POST a task whose prompt is a bare motebit_id, or JSON:
#     {"target":"<motebit_id>","checks":["identity_binding","revocation"],"receipts":[...]}
#
# The returned receipt's result payload carries a signed EvalAttestation
# (spec/eval-attestation-v1.md) — verify it independently with
# verifyEvalAttestation from @motebit/verifier. Every measurement is a
# per-axis verdict; the Auditor never manufactures a pass.

# ─── Required ───────────────────────────────────────────────────────────

# The relay whose PUBLIC endpoints are the audit evidence source. The
# fetcher is structurally pinned to this single origin (SSRF posture) —
# the Auditor never fetches target-controlled URLs. Falls back to
# MOTEBIT_SYNC_URL when unset.
MOTEBIT_RELAY_URL=https://relay.motebit.com

# ─── Trust anchor ───────────────────────────────────────────────────────

# Optional hard pin for the relay's transparency public key (hex).
# Unset ⇒ trust-on-first-use via the VERIFIED self-signature of
# /.well-known/motebit-transparency.json. Set + mismatch ⇒ the audit
# REFUSES rather than measure against an unexpected trust root.
MOTEBIT_RELAY_PUBLIC_KEY=

# ─── Service ────────────────────────────────────────────────────────────

# HTTP port for the MCP server + /health
MOTEBIT_PORT=3600

# SQLite path for the molecule's local state
MOTEBIT_DB_PATH=./data/auditor.db

# Identity dir — motebit.json/key/md generated on first boot, reused after
MOTEBIT_DATA_DIR=./data

# Optional bearer token protecting the MCP endpoint
MOTEBIT_AUTH_TOKEN=

# ─── Relay registration (marketplace presence) ─────────────────────────

# Relay base URL for register/listing/heartbeat (usually same host as
# MOTEBIT_RELAY_URL; distinct role — this one is the marketplace side)
MOTEBIT_SYNC_URL=

# API token for relay registration
MOTEBIT_API_TOKEN=

# Public URL the relay advertises for routing tasks to this service
MOTEBIT_PUBLIC_URL=

# ─── Pricing + tuning ───────────────────────────────────────────────────

# Listed price per audit task (USD). LLM-free — pure verification.
MOTEBIT_UNIT_COST=0.05

# Max delegator-supplied receipts sampled by receipt_spot_check
MOTEBIT_RECEIPT_SAMPLE_N=3

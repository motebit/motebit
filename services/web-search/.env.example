# Web Search Service — Environment Variables
#
# Quick start:
#   cd services/web-search
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3200
#
# The service self-bootstraps its motebit identity on first boot into
# ./data via bootstrapAndEmitIdentity — no manual key ceremony required.
#
# Then from another terminal:
#   motebit
#   > /mcp add web-search http://localhost:3200 --motebit
#   > Search the web for "agent protocols"

# ─── Search provider (optional) ─────────────────────────────────────────
#
# Provider chain, primary → fallback:
#   1. Tavily (TAVILY_API_KEY)     — agent-tuned, better recall on niche
#                                    or new domains. Primary when set.
#   2. Brave (BRAVE_SEARCH_API_KEY) — independent open-web index.
#   3. DuckDuckGo                  — last resort, no auth.
# Each tier is opt-in by env var; neither key set → DuckDuckGo only.

# Tavily API key — agent-native search. Preferred for first-party /
# niche queries where generic indexes misfire on homograph matches.
TAVILY_API_KEY=

# Brave Search API key — fallback when Tavily misses or is unset.
BRAVE_SEARCH_API_KEY=

# ─── Networking / storage ───────────────────────────────────────────────

# Server port (default: 3200)
MOTEBIT_PORT=3200

# Database path (default: ./data/web-search.db)
MOTEBIT_DB_PATH=./data/web-search.db

# Persistent volume root — identity files live here, survives deploys
# On Fly.io: /data. Locally: ./data
MOTEBIT_DATA_DIR=./data

# Public URL advertised to the relay (e.g. https://web-search.fly.dev)
MOTEBIT_PUBLIC_URL=

# Bearer token for inbound MCP connections (optional — motebit signed
# tokens are always accepted regardless)
MOTEBIT_AUTH_TOKEN=

# ─── Relay integration (optional) ───────────────────────────────────────

# Sync URL for discovery/registration with the canonical relay
MOTEBIT_SYNC_URL=

# API token for authenticating to the relay
MOTEBIT_API_TOKEN=

# ─── Downstream delegation (read-url) ───────────────────────────────────

# URL of the motebit read-url MCP endpoint to delegate to for the
# second hop (optional — only set when multi-hop is wired)
MOTEBIT_DELEGATE_READ_URL=

# Motebit ID of the read-url target (optional — used for relay budget binding)
MOTEBIT_DELEGATE_TARGET_ID=

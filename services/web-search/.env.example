# Web Search Service — Environment Variables
#
# Quick start:
#   cd services/web-search
#   npx create-motebit . --service    # generates motebit.md
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3200
#
# Then from another terminal:
#   motebit
#   > /mcp add web-search http://localhost:3200 --motebit
#   > Search the web for "agent protocols"

# Required: private key hex for signing execution receipts
# (printed during `npx create-motebit . --service`)
MOTEBIT_PRIVATE_KEY_HEX=

# Search provider (optional: Brave API key for better results, falls back to DuckDuckGo)
BRAVE_SEARCH_API_KEY=

# Server port (default: 3200)
MOTEBIT_PORT=3200

# Database path (default: ./data/web-search.db)
MOTEBIT_DB_PATH=./data/web-search.db

# Identity file path (default: ./motebit.md)
MOTEBIT_IDENTITY_PATH=./motebit.md

# Auth token for incoming MCP connections (optional)
MOTEBIT_AUTH_TOKEN=

# Relay registration (optional: register with discovery relay)
MOTEBIT_SYNC_URL=
MOTEBIT_API_TOKEN=

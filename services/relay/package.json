{
  "name": "@motebit/relay",
  "version": "0.0.0-private",
  "license": "BUSL-1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "relay-key": "./dist/cli.js"
  },
  "motebit": {
    "implements": [
      "spec/relay-federation-v1.md"
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; exec tsx watch src/server.ts'",
    "start": "node dist/server.js",
    "relay-key": "node dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "@motebit/circuit-breaker": "workspace:*",
    "@motebit/core-identity": "workspace:*",
    "@motebit/crypto": "workspace:*",
    "@motebit/deposit-detector": "workspace:*",
    "@motebit/encryption": "workspace:*",
    "@motebit/event-log": "workspace:*",
    "@motebit/evm-rpc": "workspace:*",
    "@motebit/market": "workspace:*",
    "@motebit/persistence": "workspace:*",
    "@motebit/protocol": "workspace:*",
    "@motebit/sdk": "workspace:*",
    "@motebit/settlement-rails": "workspace:*",
    "@motebit/treasury-reconciliation": "workspace:*",
    "@motebit/virtual-accounts": "workspace:*",
    "@motebit/wallet-solana": "workspace:*",
    "@motebit/wire-schemas": "workspace:*",
    "@coinbase/x402": "^2.1.0",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "@x402/hono": "^2.17.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.30",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@motebit/ai-core": "workspace:*",
    "@motebit/planner": "workspace:*",
    "@motebit/runtime": "workspace:*",
    "@motebit/state-export-client": "workspace:*",
    "@types/node": "^22.20.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}

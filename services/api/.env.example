# Motebit Relay — Environment Variables
#
# Quick start (local):
#   cd services/api
#   cp .env.example .env
#   pnpm dev                          # starts on :3000
#
# Nothing below is required for a bare-bones relay — the only hard
# requirement is X402_PAY_TO_ADDRESS in production. All other sections
# (Stripe, Bridge, Solana, federation) are opt-in and activate the
# corresponding rail / capability when configured.

# ─── Core ───────────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# Database path — defaults to :memory: in dev, REQUIRED in production
# On Fly.io: /data/motebit.db (backed by a volume)
MOTEBIT_DB_PATH=

# Bearer token for the admin / master-token paths (optional in dev)
MOTEBIT_API_TOKEN=

# CORS origin for browser clients (e.g. https://motebit.com)
MOTEBIT_CORS_ORIGIN=

# Passphrase for encrypting the relay's Ed25519 signing key at rest
# (PBKDF2 600K iterations — see security doctrine). Optional; if unset
# the key is stored encrypted with a zero-passphrase.
MOTEBIT_RELAY_KEY_PASSPHRASE=

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Graceful shutdown timeout in ms (default: 30000)
SHUTDOWN_TIMEOUT_MS=30000

# ─── Platform policy ────────────────────────────────────────────────────

# Platform fee rate on relay-mediated settlements (default: 0.05 = 5%)
MOTEBIT_PLATFORM_FEE_RATE=0.05

# Issue credentials on successful task receipts (default: false)
MOTEBIT_RELAY_ISSUE_CREDENTIALS=false

# Device-bound auth for multi-device sync (default: true)
MOTEBIT_ENABLE_DEVICE_AUTH=true

# Emergency freeze — blocks all economic state transitions (default: false)
MOTEBIT_EMERGENCY_FREEZE=false

# ─── Federation (relay-to-relay peering) ────────────────────────────────

# Public URL of this relay, advertised to peers in heartbeats
# When set, federation is active; leave blank to run as a singleton
MOTEBIT_FEDERATION_ENDPOINT_URL=
MOTEBIT_FEDERATION_DISPLAY_NAME=
MOTEBIT_FEDERATION_ENABLED=true
MOTEBIT_FEDERATION_AUTO_ACCEPT=false
MOTEBIT_FEDERATION_MAX_PEERS=50

# Comma-separated peer URL lists for explicit allow/block
MOTEBIT_FEDERATION_ALLOWED_PEERS=
MOTEBIT_FEDERATION_BLOCKED_PEERS=

# ─── x402 rail (HTTP-native agent payments) ─────────────────────────────

# REQUIRED in production — address that receives x402 settlement proofs
X402_PAY_TO_ADDRESS=

# CAIP-2 network id (default: eip155:84532 = Base Sepolia testnet)
X402_NETWORK=eip155:84532

# x402 facilitator URL (optional — uses default Coinbase facilitator if unset)
X402_FACILITATOR_URL=

# Testnet mode — set to "false" for mainnet (default: true)
X402_TESTNET=true

# ─── Stripe rail (fiat on-ramp + cloud subscriptions) ───────────────────

# Both are required to enable the Stripe settlement rail
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe currency code (default: usd)
STRIPE_CURRENCY=usd

# Subscription price ID for the Motebit Cloud tier
STRIPE_CLOUD_PRICE_ID=

# Shared secret between the public proxy and the relay for webhook forwarding
RELAY_PROXY_SECRET=

# ─── Bridge rail (orchestration — fiat↔crypto) ──────────────────────────

# Both are required to enable the Bridge settlement rail
BRIDGE_API_KEY=
BRIDGE_CUSTOMER_ID=

# Optional overrides
BRIDGE_SOURCE_RAIL=base
BRIDGE_SOURCE_CURRENCY=usdc
BRIDGE_API_BASE_URL=
BRIDGE_WEBHOOK_PUBLIC_KEY=

# ─── Solana (credential anchoring + revocation registry) ────────────────

# When set, credential Merkle batches and revocation events anchor onchain
# via the Solana Memo program. Without this, anchoring is Ed25519-only
# (still self-verifiable, just not onchain).
# Public mainnet: https://api.mainnet-beta.solana.com
# Devnet:         https://api.devnet.solana.com
SOLANA_RPC_URL=

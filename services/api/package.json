{
  "name": "@motebit/api",
  "version": "0.1.16",
  "license": "BSL-1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "env $(grep -v '^#' .env 2>/dev/null | grep '=' | xargs) tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/node-ws": "^1.3.0",
    "@motebit/core-identity": "workspace:*",
    "@motebit/crypto": "workspace:*",
    "@motebit/event-log": "workspace:*",
    "@motebit/market": "workspace:*",
    "@motebit/persistence": "workspace:*",
    "@motebit/sdk": "workspace:*",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/hono": "^2.6.0",
    "hono": "^4.12.9",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@motebit/ai-core": "workspace:*",
    "@motebit/planner": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

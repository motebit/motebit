{
  "name": "@motebit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@motebit/sdk": "workspace:*",
    "@motebit/ai-core": "workspace:*",
    "@motebit/event-log": "workspace:*",
    "@motebit/memory-graph": "workspace:*",
    "@motebit/state-vector": "workspace:*",
    "@motebit/behavior-engine": "workspace:*",
    "@motebit/persistence": "workspace:*",
    "@motebit/core-identity": "workspace:*",
    "@motebit/privacy-layer": "workspace:*",
    "@motebit/crypto": "workspace:*",
    "@motebit/sync-engine": "workspace:*",
    "hono": "^4.6.0",
    "hono-rate-limiter": "^0.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}

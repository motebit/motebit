# Research Service — Environment Variables
#
# Quick start (requires web-search and read-url already running):
#   cd services/research
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3400
#
# Then from another terminal:
#   motebit
#   > /mcp add research http://localhost:3400 --motebit
#   > Research the latest GENIUS Act stablecoin regulations
#
# The returned receipt's `delegation_receipts` field is the verifiable citation
# chain: every search and fetch is a signed ExecutionReceipt from web-search
# or read-url. Verifiable offline with @motebit/crypto.

# ─── Required ───────────────────────────────────────────────────────────

# Claude API key — drives the synthesis loop
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# motebit web-search MCP endpoint — research delegates here for searches
# Local default when web-search is on :3200 — adjust for your topology
MOTEBIT_WEB_SEARCH_URL=http://localhost:3200/mcp

# motebit read-url MCP endpoint — research delegates here for page fetches
MOTEBIT_READ_URL_URL=http://localhost:3500/mcp

# ─── Pricing ────────────────────────────────────────────────────────────

# Price per research report in USD (default: 0.25)
MOTEBIT_UNIT_COST=0.25

# Maximum total tool calls (search + fetch combined) per research turn (default: 8).
# Runaway-cost guard. The loop still terminates — Claude is forced into final
# synthesis when the cap is hit.
MOTEBIT_MAX_TOOL_CALLS=8

# ─── Networking / storage ───────────────────────────────────────────────

# Server port (default: 3400)
MOTEBIT_PORT=3400

# Database path (default: ./data/research.db)
MOTEBIT_DB_PATH=./data/research.db

# Persistent volume root — identity files live here, survives deploys
# On Fly.io: /data. Locally: ./data
MOTEBIT_DATA_DIR=./data

# Public URL advertised to the relay (e.g. https://research.fly.dev)
MOTEBIT_PUBLIC_URL=

# ─── Relay integration (optional but recommended) ───────────────────────

# Sync URL for discovery/registration with the canonical relay.
# When set together with MOTEBIT_API_TOKEN + the *_TARGET_ID fields, each
# atom delegation also opens a relay task for budget binding (the relay sees
# the chain of work and can settle correctly).
MOTEBIT_SYNC_URL=
MOTEBIT_API_TOKEN=

# Target motebit IDs of the atom services (looked up via the relay's discover
# endpoint). Leave blank to skip relay budget binding.
MOTEBIT_WEB_SEARCH_TARGET_ID=
MOTEBIT_READ_URL_TARGET_ID=

# Bearer token for inbound MCP connections (optional — motebit signed
# tokens are always accepted regardless)
MOTEBIT_AUTH_TOKEN=

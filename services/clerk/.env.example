# Clerk Service — Environment Variables ("The Clerk" archetype, §6)
#
# Quick start (requires a relay + a discoverable worker to hire, e.g. the Researcher):
#   cd services/clerk
#   cp .env.example .env              # fill in values below
#   pnpm dev                          # starts on :3700 (DRY_RUN defaults true)
#
# Delegate a spend:
#   POST a task whose prompt is the sub-task text, or JSON:
#     {"capability":"research","prompt":"survey the state of agent identity"}
#
# The Clerk executes a paid sub-delegation under its self-issued signed grant,
# within a self-imposed spend ceiling. An over-ceiling or out-of-scope spend is
# refused with a signed denial CODE (never the overage) — no payment. The
# returned receipt nests the worker's receipt (live) or the metered settlement
# facts (dry-run). Enforcement is the runtime's granted-spend AND, not this
# service — verify the receipt independently with @motebit/verifier.

# ─── DRY-RUN (the fail-safe default) ────────────────────────────────────

# TRUE unless explicitly disabled. When true (default/unset), the ENTIRE
# metered spine runs at hard-zero: grant verify → gate → meter → ceiling →
# refusal, with NO broadcast and the live lifetime ceiling untouched. Set to
# 0 (or false/no) to move REAL money — a deliberate operator step.
DRY_RUN=1

# ─── Required (money seam) ──────────────────────────────────────────────

# Solana RPC for the sovereign wallet rail (the Clerk's OWN funds).
MOTEBIT_SOLANA_RPC_URL=https://api.devnet.solana.com

# The relay operator's PINNED Ed25519 public key (hex) — the P2P treasury
# trust root. The fee leg derives from THIS, never a fetched response.
MOTEBIT_RELAY_PUBLIC_KEY=

# The relay to discover workers on and settle through.
MOTEBIT_SYNC_URL=

# ─── Grant (the self-imposed ceiling) ───────────────────────────────────

# Lifetime spend ceiling in micro-USD (1 USD = 1,000,000). The Clerk
# self-issues a signed standing grant committing to this bound; the
# blast-radius meter enforces it and never resets it.
MOTEBIT_CLERK_CEILING_MICRO=1000000

# Capability to hire when a task prompt does not name one.
MOTEBIT_CLERK_CAPABILITY=research

# ─── Service ────────────────────────────────────────────────────────────

# HTTP port for the MCP server + /health
MOTEBIT_PORT=3700

# SQLite path for the molecule's local state (grant-spend ledger lives here)
MOTEBIT_DB_PATH=./data/clerk.db

# Identity dir — motebit.json/key/md generated on first boot, reused after
MOTEBIT_DATA_DIR=./data

# Optional bearer token protecting the MCP endpoint
MOTEBIT_AUTH_TOKEN=

# ─── Relay registration (marketplace presence) ─────────────────────────

# API token for relay registration
MOTEBIT_API_TOKEN=

# Public URL the relay advertises for routing tasks to this service
MOTEBIT_PUBLIC_URL=

# ─── Pricing ────────────────────────────────────────────────────────────

# Listed price per delegation task (USD).
MOTEBIT_UNIT_COST=0.05

# VS Code extension build artifacts. Compiled from apps/vscode/src/ by
# `tsc -p apps/vscode/tsconfig.json`; gitignored at apps/vscode/.gitignore
# but Prettier doesn't respect nested .gitignore reliably.
apps/vscode/out

# api-extractor baselines are machine-generated; Prettier reformatting them
# causes permanent divergence from the raw extractor output that the
# check-api-surface gate compares against.
packages/*/etc/*.api.md

# CLI-surface baseline is machine-generated by scripts/check-cli-surface.ts.
# Prettier collapses short arrays to single lines; the generator always
# expands them. Without this exclusion, every `--write` regeneration
# produces a 38-line diff that prettier collapses on commit, alternating
# forever. Same shape as #api.md above.
apps/cli/etc/cli-surface.json

# Reference skills under skills/* ship as content-addressed signed
# artifacts: skill-envelope.json carries body_hash and content_hash
# computed from the EXACT bytes of SKILL.md. Prettier reformatting the
# body after signing invalidates the hashes and the envelope signature
# — exactly the drift class check-skill-corpus exists to catch. Re-sign
# via `pnpm --filter @motebit/skills build-reference-skill` if the
# content needs to change.
skills/**

# Generated from services/relay/src/transparency.ts renderer; the
# transparency sibling-boundary test asserts byte-for-byte equality
# between the committed file and renderMarkdown() output. Prettier
# reformatting it breaks that test.
services/relay/PRIVACY.md

# Tauri auto-generated schema + capability artifacts. Regenerated on
# every `cargo check` / `tauri dev` / `tauri build`; gitignored at
# apps/desktop/src-tauri/.gitignore but Prettier doesn't respect
# nested .gitignore.
apps/desktop/src-tauri/gen

# Python virtualenvs and bytecode caches created locally by example
# clients (e.g. `python -m venv .venv` inside examples/python-*). The
# example dirs gitignore them per-example, but Prettier walks the tree
# regardless of nested .gitignore and trips on vendored .js shipped in
# site-packages (e.g. urllib3's emscripten_fetch_worker.js).
**/.venv
**/venv
**/__pycache__

{
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/motebit/motebit/main/spec/schemas/agent-revocation-feed-v1.json",
  "title": "AgentRevocationFeed (v1)",
  "description": "A relay's signed, append-only agent-revocation moderation history, served at GET /api/v1/agents/revocations. The feed digest is signed; each contained record is also independently signed. See spec/agent-revocation-v1.md.",
  "type": "object",
  "properties": {
    "spec": {
      "type": "string",
      "minLength": 1,
      "description": "Spec identifier — matches the records' `spec`."
    },
    "relay_id": {
      "type": "string",
      "minLength": 1,
      "description": "The relay's MotebitId."
    },
    "relay_public_key": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Hex-encoded Ed25519 public key (32 bytes / 64 chars)."
    },
    "generated_at": {
      "type": "number",
      "description": "Epoch milliseconds when the feed snapshot was minted."
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "spec": {
            "type": "string",
            "minLength": 1,
            "description": "Spec identifier — e.g. `motebit-agent-revocation/draft-2026-06-04`."
          },
          "motebit_id": {
            "type": "string",
            "minLength": 1,
            "description": "The agent whose discoverability changed."
          },
          "revoked": {
            "type": "boolean",
            "description": "Resulting state: `true` = de-listed from Discover, `false` = reinstated."
          },
          "reason": {
            "type": "string",
            "enum": [
              "operator_test_cleanup",
              "spam",
              "abuse",
              "malware",
              "policy_violation",
              "dmca",
              "reinstated"
            ],
            "description": "Categorized reason (`AgentRevocationReason`). `reinstated` accompanies a reinstatement (`revoked: false`)."
          },
          "actor": {
            "type": "string",
            "enum": ["operator", "self"],
            "description": "Who performed the change. `operator` = master-token hygiene; `self` = the agent itself."
          },
          "note": {
            "type": "string",
            "description": "Optional free-text operator note. Not a substitute for `reason`."
          },
          "effective_at": {
            "type": "number",
            "description": "Epoch milliseconds when the change took effect."
          },
          "relay_id": {
            "type": "string",
            "minLength": 1,
            "description": "The relay's MotebitId."
          },
          "relay_public_key": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "Hex-encoded Ed25519 public key (32 bytes / 64 chars) — the trust anchor."
          },
          "hash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "Hex-encoded SHA-256 of `canonicalJson` of the signed payload."
          },
          "suite": {
            "type": "string",
            "const": "motebit-jcs-ed25519-hex-v1",
            "description": "Cryptosuite — always `motebit-jcs-ed25519-hex-v1` (JCS, Ed25519, HEX encoding)."
          },
          "signature": {
            "type": "string",
            "minLength": 1,
            "description": "Hex-encoded Ed25519 signature over the canonical-JSON signed payload."
          }
        },
        "required": [
          "spec",
          "motebit_id",
          "revoked",
          "reason",
          "actor",
          "effective_at",
          "relay_id",
          "relay_public_key",
          "hash",
          "suite",
          "signature"
        ],
        "additionalProperties": false
      },
      "description": "Every revocation state change, oldest-first — the append-only history."
    },
    "suite": {
      "type": "string",
      "const": "motebit-jcs-ed25519-hex-v1",
      "description": "Cryptosuite — always `motebit-jcs-ed25519-hex-v1`."
    },
    "signature": {
      "type": "string",
      "minLength": 1,
      "description": "Hex-encoded Ed25519 signature over canonicalJson({spec, relay_id, relay_public_key, generated_at, records})."
    }
  },
  "required": [
    "spec",
    "relay_id",
    "relay_public_key",
    "generated_at",
    "records",
    "suite",
    "signature"
  ],
  "additionalProperties": false,

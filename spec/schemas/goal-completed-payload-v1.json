{
  "$comment": "SPDX-License-Identifier: MIT",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/motebit/motebit/main/spec/schemas/goal-completed-payload-v1.json",
  "title": "GoalCompletedPayload (v1)",
  "description": "Payload of a `goal_completed` event — goal reached its terminal state. See spec/goal-lifecycle-v1.md §5.4.",
  "type": "object",
  "properties": {
    "goal_id": {
      "type": "string",
      "minLength": 1,
      "description": "UUID of the completed goal."
    },
    "reason": {
      "type": "string",
      "description": "Free-text rationale for completion. Consumers MUST NOT parse it semantically."
    }
  },
  "required": ["goal_id"],
  "additionalProperties": true,
  "definitions": {
    "GoalCompletedPayload": {
      "type": "object",
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1,
          "description": "UUID of the completed goal."
        },
        "reason": {
          "type": "string",
          "description": "Free-text rationale for completion. Consumers MUST NOT parse it semantically."
        }
      },
      "required": ["goal_id"],
      "additionalProperties": true
    }
  }
}

              }
            },
            "required": [
              "submitter_motebit_id",
              "name",
              "version",
              "content_hash",
              "description",
              "sensitivity",
              "signature_public_key",
              "featured",
              "submitted_at"
            ],
            "additionalProperties": false
          }
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "limit": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["entries", "total", "limit", "offset"],
      "additionalProperties": false
    }
  }
}

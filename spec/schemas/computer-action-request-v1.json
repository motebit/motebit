  "title": "ComputerActionRequest (v1)",
  "description": "One invocation of the `computer` tool. Action is a nested discriminated variant. See spec/computer-use-v1.md §5.1.",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1,
      "description": "Open session the action belongs to."
    },
    "action": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "screenshot"
            }
          },
          "required": ["kind"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "cursor_position"
            }
          },
          "required": ["kind"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "click"
            },
            "target": {
              "type": "object",
              "properties": {
                "x": {
                  "type": "integer",
                  "description": "Logical pixel X coordinate."
                },
                "y": {
                  "type": "integer",
                  "description": "Logical pixel Y coordinate."
                }
              },
              "required": ["x", "y"],
              "additionalProperties": false
            },
            "button": {
              "type": "string",

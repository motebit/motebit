                },
                "label": {
                  "type": "string",
                  "description": "Accessible label or visible text."
                },
                "source": {
                  "type": "string",
                  "description": "Source of the hint: 'accessibility', 'dom', 'vision', 'user_annotation'."
                }
              },
              "required": ["source"],
              "additionalProperties": false
            }
          },
          "required": ["kind", "target"],
          "additionalProperties": true
        },
        {

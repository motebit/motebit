            },
            "target_hint": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target_hint"
            }
          },
          "required": ["kind", "target"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "mouse_move"
            },
            "target": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target"
            },
            "target_hint": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target_hint"
            }
          },
          "required": ["kind", "target"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "drag"
            },
            "from": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target"
            },
            "to": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target"
            },
            "button": {
              "type": "string"
            },
            "modifiers": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/modifiers"
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 0
            },
            "target_hint": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target_hint"
            }
          },
          "required": ["kind", "from", "to"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "type"
            },
            "text": {
              "type": "string",
              "description": "Text to type."
            },
            "per_char_delay_ms": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": ["kind", "text"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "key"
            },
            "key": {
              "type": "string",
              "description": "Key combination. Example: 'cmd+c', 'escape'."
            }
          },
          "required": ["kind", "key"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "scroll"
            },
            "target": {
              "$ref": "#/definitions/ComputerActionRequest/properties/action/anyOf/2/properties/target"
            },
            "dx": {
              "type": "integer",
              "description": "Scroll wheel delta X."
            },
            "dy": {
              "type": "integer",
              "description": "Scroll wheel delta Y."
            }
          },
          "required": ["kind", "target", "dx", "dy"],
          "additionalProperties": true
        }
      ],
      "description": "Discriminated action variant. The `kind` field selects the branch."
    }
  },
  "required": ["session_id", "action"],
  "additionalProperties": true,

{
  "name": "@motebit/render-engine",
  "version": "0.0.0-private",
  "license": "BUSL-1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./spec": {
      "types": "./dist/spec.d.ts",
      "default": "./dist/spec.js"
    }
  },
  "scripts": {
    "build": "tsc -b && pnpm run build:browser",
    "build:browser": "node scripts/build-browser.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@motebit/sdk": "workspace:*",
    "@motebit/encryption": "workspace:*",
    "@motebit/policy-invariants": "workspace:*",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/three": "^0.184.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

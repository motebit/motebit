{
  "name": "@motebit/crypto",
  "version": "1.2.2",
  "description": "Sign and verify every Motebit artifact — identity files, execution receipts, credentials, delegations, succession records, credential anchors. Ed25519 today, cryptosuite-agile for post-quantum tomorrow. Apache-2.0, zero monorepo dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./suite-dispatch": {
      "types": "./dist/suite-dispatch.d.ts",
      "default": "./dist/suite-dispatch.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "keywords": [
    "motebit",
    "agent",
    "identity",
    "ed25519",
    "crypto",
    "sign",
    "verify",
    "signature",
    "receipts",
    "credentials"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/packages/crypto#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "packages/crypto"
  },
  "publishConfig": {
    "access": "public"
  },
  "motebit": {
    "implements": [
      "spec/identity-v1.md",
      "spec/credential-v1.md"
    ]
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap --outDir dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --parser-options=project:tsconfig.eslint.json src/",
    "lint:pack": "publint --strict && attw --pack --profile esm-only",
    "api:extract": "api-extractor run --local",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@motebit/protocol": "workspace:*",
    "@noble/curves": "~1.7.0",
    "@noble/ed25519": "~3.0.1",
    "@noble/hashes": "~1.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}

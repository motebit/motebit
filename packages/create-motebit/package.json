{
  "name": "create-motebit",
  "version": "1.1.0",
  "description": "Scaffold a signed Motebit identity (motebit.md) or a runnable agent service — `npm create motebit`. Apache-2.0.",
  "type": "module",
  "bin": {
    "create-motebit": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "motebit",
    "agent",
    "identity",
    "ed25519",
    "create",
    "init",
    "verify",
    "signature",
    "ai"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/packages/create-motebit#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "packages/create-motebit"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --parser-options=project:tsconfig.eslint.json src/",
    "lint:pack": "publint --strict",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@motebit/crypto": "workspace:*",
    "@noble/ed25519": "~3.0.1",
    "@noble/hashes": "~1.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}

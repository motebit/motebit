{
  "name": "@motebit/verify",
  "version": "1.0.0",
  "description": "The canonical motebit artifact verifier — CLI `motebit-verify` with every hardware-attestation platform bundled (Apple App Attest, Google Play Integrity, TPM 2.0, WebAuthn). One install, offline, self-attesting. Replaces the deprecated @motebit/verify@0.x zero-dep library: library primitives now live in @motebit/crypto; helper utilities in @motebit/verifier; this package is the tool.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "motebit-verify": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "LICENSE",
    "README.md",
    "CLAUDE.md"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "keywords": [
    "motebit",
    "verify",
    "cli",
    "hardware-attestation",
    "app-attest",
    "tpm",
    "webauthn",
    "ed25519"
  ],
  "homepage": "https://motebit.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit.git",
    "directory": "packages/verify"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --parser-options=project:tsconfig.eslint.json src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@motebit/crypto": "workspace:*",
    "@motebit/crypto-appattest": "workspace:*",
    "@motebit/crypto-play-integrity": "workspace:*",
    "@motebit/crypto-tpm": "workspace:*",
    "@motebit/crypto-webauthn": "workspace:*",
    "@motebit/verifier": "workspace:*"
  },
  "devDependencies": {
    "@noble/curves": "^1.9.0",
    "@noble/ed25519": "~3.0.1",
    "@noble/hashes": "~1.6.0",
    "@peculiar/webcrypto": "^1.5.0",
    "@peculiar/x509": "^1.12.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "name": "@motebit/verify",
  "version": "0.3.0",
  "description": "Verify motebit.md agent identity files — Ed25519 signature verification for the motebit/identity@1.0 spec",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "motebit",
    "agent",
    "identity",
    "ed25519",
    "verify",
    "signature"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/packages/verify#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "packages/verify"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --parser-options=project:tsconfig.eslint.json src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}

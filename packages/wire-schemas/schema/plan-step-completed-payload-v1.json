{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/motebit/motebit/main/packages/wire-schemas/schema/plan-step-completed-payload-v1.json",
  "title": "PlanStepCompletedPayload (v1)",
  "description": "Payload of a `plan_step_completed` event — step reached terminal success. See spec/plan-lifecycle-v1.md §5.3.",
  "type": "object",
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1,
      "description": "UUID of the parent plan."
    },
    "step_id": {
      "type": "string",
      "minLength": 1,
      "description": "UUID of the completed step."
    },
    "ordinal": {
      "type": "integer",
      "minimum": 0,
      "description": "Zero-based position of the step within its plan."
    },
    "tool_calls_made": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of tool calls the step performed."
    },
    "goal_id": {
      "type": "string",
      "description": "Owning goal when the plan serves a goal."
    }
  },
  "required": ["plan_id", "step_id", "ordinal", "tool_calls_made"],
  "additionalProperties": true,
  "definitions": {
    "PlanStepCompletedPayload": {
      "type": "object",
      "properties": {
        "plan_id": {
          "type": "string",
          "minLength": 1,
          "description": "UUID of the parent plan."
        },
        "step_id": {
          "type": "string",
          "minLength": 1,
          "description": "UUID of the completed step."
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based position of the step within its plan."
        },
        "tool_calls_made": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of tool calls the step performed."
        },
        "goal_id": {
          "type": "string",
          "description": "Owning goal when the plan serves a goal."
        }
      },
      "required": ["plan_id", "step_id", "ordinal", "tool_calls_made"],
      "additionalProperties": true
    }
  }
}

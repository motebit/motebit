{
  "name": "@motebit/crypto-play-integrity",
  "version": "1.0.0",
  "description": "Apache-2.0 verifier for Google Play Integrity hardware-attestation credentials — offline JWT signature verification against the pinned Google Play Integrity JWKS. Plugs into @motebit/crypto's HardwareAttestationVerifiers dispatcher to validate Android device-attested motebit identities.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "keywords": [
    "motebit",
    "google",
    "play-integrity",
    "attestation",
    "android",
    "hardware-attestation",
    "jwt",
    "jwks",
    "verify"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/packages/crypto-play-integrity#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "packages/crypto-play-integrity"
  },
  "publishConfig": {
    "access": "public"
  },
  "motebit": {
    "implements": [
      "spec/credential-v1.md"
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --parser-options=project:tsconfig.eslint.json src/",
    "lint:pack": "publint --strict && attw --pack --profile esm-only",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@motebit/protocol": "workspace:*",
    "@motebit/crypto": "workspace:*",
    "@noble/curves": "~1.9.0",
    "@noble/hashes": "~1.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}

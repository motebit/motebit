{
  "name": "@motebit/verifier",
  "version": "0.8.0",
  "description": "Offline third-party verifier for any signed Motebit artifact — identity files, execution receipts, credentials, presentations. MIT, standalone.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "motebit-verify": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "motebit",
    "verify",
    "ed25519",
    "signature",
    "receipt",
    "credential",
    "identity",
    "cli",
    "offline",
    "audit"
  ],
  "homepage": "https://github.com/motebit/motebit/tree/main/packages/verifier#readme",
  "bugs": {
    "url": "https://github.com/motebit/motebit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit",
    "directory": "packages/verifier"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --parser-options=project:tsconfig.eslint.json src/",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@motebit/crypto": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}

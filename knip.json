{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": [
    "apps/inspector",
    "apps/operator",
    "apps/desktop",
    "apps/mobile",
    "apps/spatial",
    "apps/docs"
  ],
  "ignoreDependencies": ["@motebit/*", "@changesets/changelog-github", "better-sqlite3", "motebit"],
  "ignoreBinaries": ["tauri"],
  "ignore": [
    "examples/**",
    "packages/wire-schemas/src/__parity/**",
    "scripts/__tests__/affordance-routing-fixture/**",
    "packages/sdk/src/credential-types-doc.ts"
  ],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{ts,mjs}"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/cli": {
      "project": ["src/**/*.ts"],
      "comment": "apps/cli is an esbuild bundle that EXTERNALIZES node_modules; deps imported only by the bundled @motebit/* runtime closure (not by apps/cli/src) must stay direct deps for the dist binary to boot (check-dist-smoke), so knip can't see them in src.",
      "ignoreDependencies": [
        "@modelcontextprotocol/sdk",
        "sql.js",
        "ws",
        "stripe",
        "@noble/curves",
        "@solana/web3.js",
        "@solana/spl-token",
        "@x402/core",
        "@x402/hono",
        "@hono/node-ws"
      ]
    },
    "apps/web": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["three", "@types/three", "buffer"]
    },
    "apps/identity": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "services/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@modelcontextprotocol/sdk", "tsx"]
    },
    "services/proxy": {
      "entry": ["src/app/**/*.{ts,tsx}", "src/validation.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "exclude": ["types", "enumMembers"]
}

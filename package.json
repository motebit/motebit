{
  "name": "motebit-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "BSL-1.1",
  "description": "Cryptographic identity for AI agents",
  "homepage": "https://motebit.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit.git"
  },
  "keywords": [
    "ai",
    "agent",
    "identity",
    "cryptography",
    "ed25519",
    "mcp",
    "trust",
    "governance"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check-deps": "npx tsx scripts/check-deps.ts",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.8.20",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11 <8.0.0",
      "node-fetch": ">=2.6.7 <3.0.0",
      "hono": ">=4.12.4 <5.0.0",
      "@hono/node-server": ">=1.19.10 <2.0.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup": ">=4.59.0 <5.0.0",
      "express-rate-limit": ">=8.2.2 <9.0.0",
      "esbuild": ">=0.25.0 <0.28.0",
      "undici": ">=6.24.0 <7.0.0",
      "flatted": ">=3.4.2 <4.0.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react-dom>react": "18",
        "expo-three>three": ">=0.170.0",
        "@expo/browser-polyfill>react": "18",
        "@expo/browser-polyfill>react-native": ">=0.76.0",
        "@expo/browser-polyfill>expo-file-system": ">=17.0.0",
        "react-helmet-async>react-dom": "19"
      }
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}

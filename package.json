{
  "name": "motebit-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "BSL-1.1",
  "description": "Cryptographic identity for AI agents",
  "homepage": "https://motebit.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/motebit/motebit.git"
  },
  "keywords": [
    "ai",
    "agent",
    "identity",
    "cryptography",
    "ed25519",
    "mcp",
    "trust",
    "governance"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "node-fetch": ">=2.6.7",
      "hono": ">=4.11.10"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react-dom>react": "18",
        "expo-three>three": ">=0.170.0",
        "@expo/browser-polyfill>react": "18",
        "@expo/browser-polyfill>react-native": ">=0.76.0",
        "@expo/browser-polyfill>expo-file-system": ">=17.0.0",
        "react-helmet-async>react-dom": "19"
      }
    }
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}

{
  "dashboard": {
    "title": "Mote System Overview",
    "tags": ["mote"],
    "panels": [
      {
        "title": "State Vector Distribution",
        "type": "histogram",
        "targets": [
          {
            "expr": "mote_state_vector_attention",
            "legendFormat": "attention"
          },
          {
            "expr": "mote_state_vector_confidence",
            "legendFormat": "confidence"
          },
          {
            "expr": "mote_state_vector_affect_arousal",
            "legendFormat": "affect_arousal"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(mote_errors_total[5m])",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "title": "API Latency (p95)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, mote_api_request_duration_seconds_bucket)",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "title": "Sync Status",
        "type": "stat",
        "targets": [
          {
            "expr": "mote_sync_events_pushed_total",
            "legendFormat": "pushed"
          },
          {
            "expr": "mote_sync_events_pulled_total",
            "legendFormat": "pulled"
          },
          {
            "expr": "mote_sync_conflicts_total",
            "legendFormat": "conflicts"
          }
        ]
      },
      {
        "title": "Memory Graph Size",
        "type": "gauge",
        "targets": [
          {
            "expr": "mote_memory_nodes_total",
            "legendFormat": "nodes"
          },
          {
            "expr": "mote_memory_edges_total",
            "legendFormat": "edges"
          }
        ]
      }
    ]
  }
}
